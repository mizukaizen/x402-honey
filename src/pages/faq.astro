---
import Layout from '../components/Layout.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What is x402?", "acceptedAnswer": { "@type": "Answer", "text": "x402 is an open payment protocol for machine-to-machine micropayments. When a service requires payment, it returns HTTP 402 (Payment Required) with a signed payment quote. Your wallet client signs the payment in USDC on Base and retries the request. No accounts, no API keys, no subscriptions." } },
    { "@type": "Question", "name": "What is MCP?", "acceptedAnswer": { "@type": "Answer", "text": "MCP (Model Context Protocol) is the dominant agent integration layer, introduced by Anthropic. It lets AI agents call external tools as functions. With npx @melis-ai/x402-tools-mcp, all 22 services become callable tools in any MCP-aware agent environment." } },
    { "@type": "Question", "name": "How does my agent pay?", "acceptedAnswer": { "@type": "Answer", "text": "Your agent's x402-enabled wallet client handles payment automatically. When a service returns 402, the client signs a USDC payment on Base and retries. Payment only settles on successful 2xx response with non-empty content." } },
    { "@type": "Question", "name": "Do I need an account?", "acceptedAnswer": { "@type": "Answer", "text": "No. x402 is account-less. Your wallet is your identity. No registration, no API key, no subscription required." } },
    { "@type": "Question", "name": "Is there a free tier?", "acceptedAnswer": { "@type": "Answer", "text": "No free tier. Every call is paid. Prices start at $0.001 USDC per call." } },
    { "@type": "Question", "name": "What chains and currencies are supported?", "acceptedAnswer": { "@type": "Answer", "text": "USDC on Base only. Base is Coinbase's Ethereum L2 with fast finality (~2 seconds) and low gas costs." } },
    { "@type": "Question", "name": "How is this different from Orbis?", "acceptedAnswer": { "@type": "Answer", "text": "Orbis is an aggregator bundling thousands of services. melis x402 Tools is a curated set of 22 services, each security-audited with charge-on-failure safety, SSRF hardening, and robots.txt enforcement." } },
    { "@type": "Question", "name": "Where is the source code?", "acceptedAnswer": { "@type": "Answer", "text": "Service code is closed-source for security. The MCP wrapper is open-source (MIT) at github.com/mizukaizen/x402-tools-mcp." } },
    { "@type": "Question", "name": "What happens if a service is down?", "acceptedAnswer": { "@type": "Answer", "text": "Services return an appropriate HTTP error code. Payment is not settled on non-2xx responses, so failed calls are not charged." } },
    { "@type": "Question", "name": "Who built this?", "acceptedAnswer": { "@type": "Answer", "text": "Sean Melis (sean@melis.ai), AI agent operator and builder based in London, UK. Part of the melis.ai agent infrastructure stack." } },
    { "@type": "Question", "name": "How do I build an x402 RAG pipeline?", "acceptedAnswer": { "@type": "Answer", "text": "The canonical x402 RAG pipeline uses 5 services: (1) ScrapePay ($0.01) to fetch the source page via Playwright, (2) MarkdownOpt ($0.005) to clean it to LLM-ready markdown, (3) EmbedPay ($0.0003 for 5k tokens) to generate a 1536-dim vector, (4) MemoryServe ($0.001) to store the vector + content with agent namespace, (5) MEMSCRUB ($0.001) to scan each retrieved chunk for indirect prompt injection before passing to the LLM. Total: ~$0.017 per page. See agents.melis.ai/pipelines/rag for a full walkthrough." } },
    { "@type": "Question", "name": "What is the difference between PromptGuard and MEMSCRUB?", "acceptedAnswer": { "@type": "Answer", "text": "PromptGuard ($0.002) scans direct user input for prompt injection attacks before they reach the LLM — jailbreaks, role overrides, privilege escalation. MEMSCRUB ($0.001) scans retrieved content from external sources — RAG chunks, tool outputs, scraped text — for indirect injection attacks: HTML comment injection, invisible Unicode, fake system messages, exfiltration instructions. Use both in a safety pipeline: PromptGuard on the way in, MEMSCRUB on each retrieved document before context assembly." } },
    { "@type": "Question", "name": "Can I use MemoryServe without EmbedPay?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. If you already have a vector, pass it directly in the vector field of the /memory/write request and MemoryServe will skip the EmbedPay call. This is useful if you are using your own embedding model or a different provider. When a vector is not supplied, MemoryServe calls EmbedPay automatically using openai-3-small (1536 dimensions, cl100k_base tokenisation, $0.00005 per 1k tokens)." } },
    { "@type": "Question", "name": "What does a full x402 RAG pipeline cost?", "acceptedAnswer": { "@type": "Answer", "text": "For a 5k-token source page: ScrapePay $0.01 + MarkdownOpt $0.005 + EmbedPay $0.0003 + MemoryServe write $0.001 + MEMSCRUB $0.001 = approximately $0.017 total. Query cost (retrieval only): EmbedPay $0.0003 + MemoryServe query $0.001 + MEMSCRUB per chunk $0.001 = approximately $0.002 per query. All prices in USDC on Base." } },
    { "@type": "Question", "name": "How does Loopwall prevent agent loops?", "acceptedAnswer": { "@type": "Answer", "text": "Loopwall is the orchestration spine for safe multi-agent chains. Call /issue at chain start ($0.001) to mint a signed Job Envelope with origin, max_hops, and USD budget cap. Then call /hop at each subsequent step ($0.0005) to validate against loop detection, hop-limit, and remaining budget. The envelope is cryptographically signed so any downstream agent can verify chain provenance without trusting the caller. Unlike in-process loop counters, Loopwall works across runtimes and organisations — any agent that can POST HTTP can participate in a protected chain." } },
    { "@type": "Question", "name": "What's the difference between PromptGuard and xAudit?", "acceptedAnswer": { "@type": "Answer", "text": "PromptGuard ($0.002) scores INPUT strings for prompt injection risk before they reach the LLM — jailbreaks, role overrides, system prompt extraction. xAudit ($0.002) validates OUTPUT content for factual quality and returns a cryptographically signed certificate of the audit. Different layers of the safety stack: PromptGuard guards the entry, xAudit guards the exit. SchemaGate sits between them for structural validation. Use all three for end-to-end response safety." } },
  ],
};
---

<Layout
  title="FAQ"
  description="Frequently asked questions about melis x402 tools. What is x402? What is MCP? How does payment work? Comparison with Orbis, Exa, StableEnrich, and others."
  breadcrumbs={[{ name: 'FAQ', url: 'https://agents.melis.ai/faq' }]}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>
  <div class="container" style="padding-top:4rem;padding-bottom:4rem;">
    <h1>FAQ</h1>
    <p class="subtitle">The questions agents and their builders ask most often.</p>

    <div class="faq-grid">

      <div class="faq-section">
        <h2>The protocol</h2>

        <div class="faq-item">
          <h3>What is x402?</h3>
          <p>
            x402 is an open payment protocol for machine-to-machine micropayments. When a service requires
            payment, it returns HTTP 402 (Payment Required) with a signed payment quote. Your wallet client
            signs the payment in USDC on Base and retries the request. The service verifies the payment
            header and returns the result. No accounts, no API keys, no subscriptions.
          </p>
          <p>
            x402 joined the Linux Foundation in April 2026 with Google, AWS, Microsoft, Stripe, Visa,
            Mastercard, and 20+ other founding members. It is now the dominant micropayment protocol for
            AI agents. See <a href="https://x402.org" target="_blank" rel="noopener">x402.org</a> for the spec.
          </p>
        </div>

        <div class="faq-item">
          <h3>What is MCP?</h3>
          <p>
            MCP (Model Context Protocol) is the dominant agent integration layer, introduced by Anthropic.
            It lets AI agents call external tools as functions. With the melis x402 Tools MCP server
            (<code>npx @melis-ai/x402-tools-mcp</code>), all 22 services become callable tools in any
            MCP-aware agent environment — Claude Desktop, Cursor, Claude Code, Continue, and others.
          </p>
        </div>

        <div class="faq-item">
          <h3>How does my agent pay?</h3>
          <p>
            Your agent's x402-enabled wallet client handles payment automatically. When a service returns
            402, the client signs a USDC payment on Base and retries. If you're integrating directly via
            HTTP, you'll need an x402 client library. If you're using the MCP server, payment handling
            depends on your MCP client's x402 support — some clients handle it natively, others require
            the <code>X402_PAYMENT_HEADER</code> environment variable pre-populated from your wallet.
          </p>
        </div>

        <div class="faq-item">
          <h3>What happens if a call fails?</h3>
          <p>
            Payment is not settled on failure. This is enforced at the SDK level across all 22 services.
            If the service returns anything other than HTTP 2xx with non-empty content, the x402 SDK
            does not settle the payment. This was a known bug in v1.0.0 (charge-on-failure was incorrectly
            triggered on any non-5xx, including 4xx errors). It was patched and the full fleet was rebuilt
            on 2026-05-07.
          </p>
        </div>

        <div class="faq-item">
          <h3>Is x402 the same as Stripe MPP?</h3>
          <p>
            No. Stripe MPP (March 2026) sits one layer above x402 in the stack — it's a higher-level
            abstraction for agentic payments with enterprise partners (Anthropic, OpenAI, DoorDash, Visa,
            Shopify, etc.). x402 is the lower-level protocol for direct HTTP micropayments. The two are
            described as complementary, not competing. x402 is what melis services use.
          </p>
        </div>
      </div>

      <div class="faq-section">
        <h2>Using the services</h2>

        <div class="faq-item">
          <h3>Do I need an account?</h3>
          <p>
            No. x402 is account-less. If you're testing with an issued internal key, we provide that
            directly — no signup flow. For production x402 payments, your wallet is your identity.
          </p>
        </div>

        <div class="faq-item">
          <h3>Is there a free tier?</h3>
          <p>
            No free tier. Every call is paid. The prices start at $0.001 USDC — $1 buys you 1,000 schema
            validation calls. The model is intentionally simple: you pay for what you use, nothing else.
          </p>
        </div>

        <div class="faq-item">
          <h3>Can I get a refund?</h3>
          <p>
            Charge-on-failure-safe means you shouldn't need one — failed calls don't settle. If you
            believe you were charged for a call that failed, email sean@melis.ai with the transaction
            hash. A manual review will be conducted. The only confirmed past incident was tx
            <code>0x46e6edbc…</code> (ScrapePay v1.0.0, 2026-05-07) — the recipient was identified and
            a refund is pending.
          </p>
        </div>

        <div class="faq-item">
          <h3>Are there per-IP or per-call limits?</h3>
          <p>
            NotifyRelay is rate-limited at 10 requests per minute per IP (enforced via
            express-rate-limit, HTTP 429 on breach). PDF Render has per-IP daily limits
            (contact sean@melis.ai for details). The other 14 services have no published rate limit.
            For bulk volume (&gt;10,000 calls/month), email to arrange an internal key with monthly
            invoicing.
          </p>
        </div>

        <div class="faq-item">
          <h3>What chains and currencies are supported?</h3>
          <p>
            USDC on Base only. Base is Coinbase's Ethereum L2 — fast finality (~2 seconds), low gas.
            Other chains and currencies are not currently supported.
          </p>
        </div>
      </div>

      <div class="faq-section">
        <h2>Comparisons</h2>

        <div class="faq-item">
          <h3>How is this different from Orbis?</h3>
          <p>
            Orbis is an aggregator — it bundles thousands of services into a single marketplace. Useful
            for breadth. melis x402 Tools is a curated set of 22 services, each security-audited, with
            charge-on-failure safety, SSRF hardening, and robots.txt enforcement. Orbis handles volume
            (40,800 calls/24h); melis handles correctness and safety for boring infrastructure tasks.
          </p>
        </div>

        <div class="faq-item">
          <h3>How is this different from StableEnrich?</h3>
          <p>
            StableEnrich bundles Apollo, Clado, Exa, Firecrawl, Maps, Serper, Whitepages, and others —
            primarily data enrichment and research services. melis x402 Tools focuses on utility
            primitives: scrape, validate, convert, notify, guard. The overlap is ScrapePay vs Firecrawl.
            ScrapePay enforces robots.txt and charge-on-failure; Firecrawl does not guarantee both.
          </p>
        </div>

        <div class="faq-item">
          <h3>How is this different from Exa?</h3>
          <p>
            Exa is a neural search engine over a proprietary indexed corpus. Great for broad research
            and finding semantically similar documents. ScrapePay fetches the live web page via
            Playwright — better for dynamic JS-rendered content, very fresh information, or pages Exa
            hasn't indexed. Exa requires a subscription; ScrapePay is $0.01 per call with no account.
          </p>
        </div>

        <div class="faq-item">
          <h3>How is this different from BlockRun?</h3>
          <p>
            BlockRun is an x402 AI model gateway — access to 55+ LLMs via x402. melis x402 Tools is
            for utility infrastructure around LLM calls (scraping, validating, converting, notifying) —
            not the models themselves. The two are complementary, not competing.
          </p>
        </div>

        <div class="faq-item">
          <h3>How is this different from agentsvc.io?</h3>
          <p>
            agentsvc.io offers 20 utility tools at similar price points ($0.001–$0.008). The overlap
            is real. melis x402 Tools differentiates on security hardening (SSRF protection, robots.txt
            enforcement, charge-on-failure), composition documentation, and the MCP wrapper that gives
            one-command access to all 22 services.
          </p>
        </div>
      </div>

      <div class="faq-section">
        <h2>Security and transparency</h2>

        <div class="faq-item">
          <h3>Where is the source code?</h3>
          <p>
            Service code is closed-source. The MCP wrapper is open-source (MIT):{' '}
            <a href="https://github.com/mizukaizen/x402-tools-mcp" target="_blank" rel="noopener">
              github.com/mizukaizen/x402-tools-mcp
            </a>.
          </p>
        </div>

        <div class="faq-item">
          <h3>How do I verify payments are going where you say?</h3>
          <p>
            Every payment settles on-chain. The microservices wallet (13 services) is{' '}
            <a
              href="https://basescan.org/address/0x1C680703D6cF7dfC9FEABb5AA28E64B869ddB3bC#tokentxns"
              target="_blank" rel="noopener"
            >
              0x1C68…B3bC on Basescan
            </a>.
            The Molt Swarm wallet (3 services) is{' '}
            <a
              href="https://basescan.org/address/0x61F2eF18ab0630912D24Fd0A30288619735AfFf5#tokentxns"
              target="_blank" rel="noopener"
            >
              0x61F2…AfFf5 on Basescan
            </a>.
            Both wallets are publicly viewable.
          </p>
        </div>

        <div class="faq-item">
          <h3>What is the SSRF hardening you mention?</h3>
          <p>
            Server-Side Request Forgery (SSRF) is a class of attack where a user tricks a server into
            making requests to internal network addresses (e.g. <code>http://169.254.169.254/</code> to
            retrieve cloud metadata, or <code>http://127.0.0.1:3011/</code> to reach internal services).
            All services that accept user-supplied URLs (ScrapePay, CacheServe, LinkRisk, LinkSafe,
            NotifyRelay /webhook, Screenshot, PDF Render) resolve the hostname via DNS before making
            any request, and block private IP ranges (127.x, 10.x, 172.16–31.x, 192.168.x, 169.254.x)
            and non-http/https schemes. A full security audit was conducted on 2026-05-07; all 4 critical
            findings were closed in the same session.
          </p>
        </div>

        <div class="faq-item">
          <h3>Who built this?</h3>
          <p>
            Sean Melis (sean@melis.ai), AI agent operator and builder based in London, UK. Runs
            OpenClaw multi-agent system on a dedicated Helsinki VPS. The x402 services are part of
            the infrastructure stack built to power those agents, opened to the public as
            x402-priced utilities.
          </p>
        </div>

        <div class="faq-item">
          <h3>What happens if a service is down?</h3>
          <p>
            Services return an appropriate HTTP error code. If the service is unreachable, your x402
            client will not settle payment (no 2xx response). Last known fleet status: 22 green / 0 red
            as of 2026-05-07. No SLA is published currently.
          </p>
        </div>
      </div>

      <div class="faq-section">
        <h2>EmbedPay, MEMSCRUB, and MemoryServe</h2>

        <div class="faq-item">
          <h3>How do I build a RAG pipeline using melis services?</h3>
          <p>
            The canonical x402 RAG pipeline is: ScrapePay → MarkdownOpt → EmbedPay → MemoryServe
            /memory/write → MEMSCRUB /scrub. ScrapePay fetches the live page; MarkdownOpt strips
            HTML noise; EmbedPay generates a 1536-dim embedding via OpenAI text-embedding-3-small;
            MemoryServe stores it in Qdrant with SQLite metadata; MEMSCRUB scans retrieved chunks
            before they reach your LLM to block indirect prompt injection. Total cost: ~$0.017 per
            5k-token page. See <a href="/pipelines/rag">The canonical RAG pipeline</a> for a full
            walkthrough.
          </p>
        </div>

        <div class="faq-item">
          <h3>What's the difference between PromptGuard and MEMSCRUB?</h3>
          <p>
            PromptGuard ($0.002) screens user-supplied input before it reaches your LLM — it catches
            direct prompt injection attempts in things users type or paste. MEMSCRUB ($0.001) screens
            content retrieved from external sources (web pages, documents, RAG chunks) before it
            reaches your LLM — it catches indirect prompt injection planted in third-party content.
            Use both in a complete pipeline: PromptGuard on user input, MEMSCRUB on retrieved context.
          </p>
        </div>

        <div class="faq-item">
          <h3>Can I use MemoryServe without EmbedPay?</h3>
          <p>
            No. MemoryServe calls EmbedPay internally (via Docker network) to generate embeddings
            before writing to Qdrant. EmbedPay is a hard dependency — it handles the OpenAI
            text-embedding-3-small call and bills you $0.00005 per 1k tokens. Both services must
            be running. If you supply your own embeddings (1536-dim vectors), contact
            sean@melis.ai about a raw-vector write endpoint.
          </p>
        </div>

        <div class="faq-item">
          <h3>What does a full RAG pipeline cost per page?</h3>
          <p>
            For a typical 5k-token web page: ScrapePay $0.010 + MarkdownOpt $0.005 + EmbedPay
            ~$0.0003 (5k tokens at $0.00005/1k) + MemoryServe write $0.001 + MEMSCRUB scrub $0.001
            = approximately $0.017 per page ingested and secured. Query cost is an additional
            $0.001 per semantic search (MemoryServe /memory/query) plus one EmbedPay call to embed
            the query (~$0.00001).
          </p>
        </div>

      </div>

    </div>
  </div>
</Layout>

<style>
h1 { font-size: 2rem; margin-bottom: 0.75rem; }
.subtitle { color: var(--text-2); margin-bottom: 3rem; }

.faq-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(440px, 1fr));
  gap: 3rem;
  align-items: start;
}

.faq-section h2 {
  font-size: 13px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--text-3);
  margin-bottom: 1.5rem;
  padding-bottom: 0.5rem;
  border-bottom: 1px solid var(--border);
}

.faq-item {
  margin-bottom: 1.5rem;
}

.faq-item h3 {
  font-size: 14px;
  font-weight: 600;
  margin-bottom: 0.5rem;
  color: var(--text);
}

.faq-item p {
  font-size: 14px;
  color: var(--text-2);
  line-height: 1.7;
  margin-bottom: 0.5rem;
}

@media (max-width: 900px) {
  .faq-grid { grid-template-columns: 1fr; }
}
</style>
