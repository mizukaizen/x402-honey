---
import Layout from '../components/Layout.astro';
---

<Layout title="404 — Not found" description="Page not found.">
  <div class="container" style="padding-top:6rem;padding-bottom:6rem;text-align:center;">
    <p style="font-family:var(--font-mono);font-size:48px;color:var(--text-3);">404</p>
    <h1 style="margin-top:1rem;margin-bottom:0.5rem;">Page not found.</h1>
    <p style="color:var(--text-2);">
      <a href="/">← Back to home</a> or <a href="/services">browse all services</a>.
    </p>
  </div>
</Layout>
