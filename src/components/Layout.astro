---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title,
  description,
  canonical = Astro.url.href,
  ogImage = 'https://agents.melis.ai/og.png',
} = Astro.props;

const fullTitle = title.includes('melis') ? title : `${title} — melis x402 Tools`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0A0A0A" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@melisarchimedes" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <slot name="head" />
  </head>
  <body>
    <nav class="nav">
      <div class="nav-inner">
        <a href="/" class="nav-logo">
          <span class="bee">✦</span>
          melis x402 tools
        </a>
        <ul class="nav-links">
          <li class="hide-mobile"><a href="/services">Services</a></li>
          <li class="hide-mobile"><a href="/pricing">Pricing</a></li>
          <li class="hide-mobile"><a href="/compose">Compose</a></li>
          <li class="hide-mobile"><a href="/docs/install-mcp">Docs</a></li>
          <li class="hide-mobile"><a href="/faq">FAQ</a></li>
          <li>
            <a
              href="https://www.npmjs.com/package/@melis-ai/x402-tools-mcp"
              class="cta"
              target="_blank"
              rel="noopener"
            >
              npm install →
            </a>
          </li>
        </ul>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="footer-inner">
        <div class="footer-brand">
          <span>✦ melis x402 tools</span>
          <p>Boring infrastructure for AI agents.<br />Built by <a href="https://melis.ai">Sean Melis</a>. Based in Australia.</p>
        </div>

        <div class="footer-links">
          <div class="footer-group">
            <h4>Services</h4>
            <ul>
              <li><a href="/services/scrapepay">ScrapePay</a></li>
              <li><a href="/services/markdownopt">MarkdownOpt</a></li>
              <li><a href="/services/promptguard">PromptGuard</a></li>
              <li><a href="/services">All 16 →</a></li>
            </ul>
          </div>

          <div class="footer-group">
            <h4>Docs</h4>
            <ul>
              <li><a href="/docs/install-mcp">MCP Install</a></li>
              <li><a href="/docs/x402-payment">x402 Protocol</a></li>
              <li><a href="/docs/compare">Alternatives</a></li>
              <li><a href="/compose">Compose</a></li>
            </ul>
          </div>

          <div class="footer-group">
            <h4>Links</h4>
            <ul>
              <li><a href="/llms.txt">llms.txt</a></li>
              <li><a href="/llms-full.txt">llms-full.txt</a></li>
              <li>
                <a
                  href="https://www.npmjs.com/package/@melis-ai/x402-tools-mcp"
                  target="_blank" rel="noopener"
                >npm package</a>
              </li>
              <li>
                <a
                  href="https://basescan.org/address/0x1C680703D6cF7dfC9FEABb5AA28E64B869ddB3bC#tokentxns"
                  target="_blank" rel="noopener"
                >Basescan wallet</a>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
