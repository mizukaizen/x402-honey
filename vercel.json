{
  "outputDirectory": "dist",
  "buildCommand": "npm run build",
  "functions": {
    "api/activity.ts": {
      "maxDuration": 15
    }
  },
  "rewrites": [
    { "source": "/brief/:slug", "destination": "https://bundles.melis.ai/:slug" },
    { "source": "/brief/:slug/:variant", "destination": "https://bundles.melis.ai/:slug/:variant" }
  ]
}
